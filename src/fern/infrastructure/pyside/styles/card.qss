/* Cards — subtle and flat */

#fernCard {
    background-color: #1f1f23;
    border: 1px solid #27272a;
    border-radius: 6px;
    min-width: 160px;
    min-height: 64px;
}

#fernCard:hover {
    background-color: #27272a;
    border-color: #3f3f46;
}

#fernCardIcon {
    background-color: transparent;
}

#fernCardTitle {
    color: #d4d4d8;
    font-size: 12px;
    font-weight: 500;
}

#fernCardSubtitle {
    color: #52525b;
    font-size: 11px;
}
